{
  "name": "marble-madness",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:auto": "node ../tools/dev-auto/watch-versioned-build.mjs --config dev-auto.config.json",
    "dev:restart": "node ../tools/dev-auto/restart-dev-server.mjs --config dev-auto.config.json",
    "dev:restart:bg": "node ../tools/dev-auto/restart-dev-server.mjs --config dev-auto.config.json --background --log-file dev.log",
    "build": "vite build && node ../tools/dev-auto/read-build-version.mjs --config dev-auto.config.json",
    "build:version": "node ../tools/dev-auto/read-build-version.mjs --config dev-auto.config.json",
    "build:versioned": "node ../tools/dev-auto/bump-build-version.mjs --config dev-auto.config.json && vite build && node ../tools/dev-auto/read-build-version.mjs --config dev-auto.config.json",
    "build:versioned:serve": "npm run build:versioned && npm run dev:restart",
    "preview": "vite preview",
    "review:serve": "node tools/pass-review/server.mjs",
    "review:publish": "node tools/pass-review/publish-pass.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,html}'"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@oasiz/sdk": "^1.0.1",
    "three": "^0.181.1"
  },
  "devDependencies": {
    "@types/three": "^0.181.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-singlefile": "^2.0.3"
  }
}
