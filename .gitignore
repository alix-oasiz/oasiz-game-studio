# Dependencies
node_modules/

# Build output
dist/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor directories and files
.idea/
*.swp
*.swo



# Local env files
.env
.env.local
.env.*.local

# Track asset folders inside Space Force only
!space-force/**/asset/
!space-force/**/asset/**
!space-force/**/assets/
!space-force/**/assets/**
!space-force/src/audio/
!space-force/src/audio/**

# Space Force: local tooling/runtime artifacts
space-force/.tools/ffmpeg/
space-force/.claude/
space-force/docs/plans/
space-force/server/observed-runs/*
!space-force/server/observed-runs/dashboard/
!space-force/server/observed-runs/dashboard/**
!space-force/server/observed-runs/index.json

# Unity - auto-generated folders (safe to regenerate)
Unity/*/Library/
Unity/*/Temp/
Unity/*/Logs/
Unity/*/obj/
Unity/*/Build/
Unity/*/Builds/
Unity/*/UserSettings/
Unity/*/.vs/

# Unity - OS & editor artifacts inside Unity projects
Unity/**/.DS_Store
Unity/**/Thumbs.db
Unity/**/*.pidb
Unity/**/*.suo
Unity/**/*.userprefs
Unity/**/*.unityproj
Unity/**/*.booproj

# Unity - crash & sysinfo files
Unity/**/crashlytics-build.properties
Unity/**/sysinfo.txt

# Unity - compiled output
Unity/**/*.apk
Unity/**/*.aab
Unity/**/*.unitypackage
Unity/**/*.app

